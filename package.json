{
  "name": "glyph-weaver",
  "version": "0.1.0",
  "private": true,
  "description": "A tool for crafting and manipulating symbolic glyph systems, runic alphabets, and custom character sets. Monorepo root.",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.5.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r build && pnpm -r typecheck",
    "lint": "eslint . --ext .ts,.tsx --ignore-pattern dist --ignore-pattern .next --ignore-pattern node_modules",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "run-all-checks": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "check-encoding": "pwsh scripts/check-encoding.ps1",
    "clean": "pnpm -r exec rm -rf dist .tsbuildinfo"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  }
}
